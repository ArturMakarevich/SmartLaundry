# Copy to .env and fill in values

# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=yourdomain.onrender.com,www.yourdomain.com

# Database — Supabase connection string (postgresql://...)
DATABASE_URL=postgres://user:password@host:5432/dbname

# Redis — Upstash connection string (rediss://...)
REDIS_URL=rediss://default:password@host.upstash.io:6379

# CORS — Vercel frontend origin
FRONTEND_ORIGIN=https://your-app.vercel.app

# Email (Gmail SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=SmartLaundry <your@gmail.com>

# Gemini API (free tier: 1500 req/day) — get key at aistudio.google.com
GEMINI_API_KEY=
